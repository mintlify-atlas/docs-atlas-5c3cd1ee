  "keyFeatures": [
    "10-framework deep psychology interview engine (Western depth, Western supplement, Eastern reflection)",
    "Multi-persona extraction into structured PLOON format (persona.md, nuance.md, accounts.md)",
    "5-agent content pipeline: profiler → trendsetter → content-writer → virtual-follower → admin",
    "Platform-specific content generation for X, Threads, LinkedIn, Naver Blog, and Brunch",
    "Virtual follower QA simulation with 20 audience archetypes and TOP 5 draft selection",
    "Portability: personas export to CLAUDE.md or AGENTS.md for use in any AI agent runtime",
    "Local-first dashboard built with Hono + React for pipeline visibility",
    "Lifecycle hooks for session start, pre-tool use, and post-tool use"
  ],
  "publicApiSurface": [
    "GET /api/personas",
    "GET /api/personas/:id",
    "GET /api/personas/:id/interview-log",
    "GET /api/personas/:id/qa-simulation",
    "GET /api/content/drafts",
    "GET /api/content/published",
    "GET /api/agents/status",
    "GET /api/status",
    "$interview / /interview — start or resume psychology interview",
    "$introduce / /introduce — inject persona into active session",
    "$trend / /trend — scan trending topics matched to persona",
    "$content [platform] / /content [platform] — generate platform-specific drafts",
    "$qa / /qa — run virtual follower QA simulation",
    "$publish / /publish — publish and track content",
    "$status / /status — show pipeline and persona status",
    "$export / /export — export persona to CLAUDE.md or AGENTS.md"
  ]
}
